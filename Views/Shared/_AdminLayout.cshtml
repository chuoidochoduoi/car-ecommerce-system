<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - firstWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
     <link rel="stylesheet" href="~/css/AdminUI/dashbroad.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <div id="sidebarOverlay" class="overlay"></div>


        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header d-flex justify-content-between align-items-center p-3">
                <h4 class="sidebar-title mb-0">Devomate Admin</h4>
                <button class="btn btn-light d-lg-none" id="closeSidebar"><i class="bi bi-x-lg"></i></button>
            </div>

            <ul class="sidebar-menu list-unstyled mt-3">
                <!-- Main -->
                <li class=""><a href="/admin/dashboard"><i class="bi bi-speedometer2"></i> <span>Dashboard</span></a></li>
                <li><a href="/admin/orderlist"><i class="bi bi-bag-check-fill"></i> <span>Orders</span></a></li>
            <li><a href="/admin/message"><i class="bi bi-cash-stack"></i> <span>Message</span></a></li>
                <li><a href="/admin/car-manager"><i class="bi bi-box-seam"></i> <span>Car Manager</span></a></li>
                <li><a href="product_stock.html"><i class="bi bi-stack"></i> <span>Product Stock</span></a></li>

                <!-- Dropdown -->
                <li>
                    <a href="#dropSubmenu" data-bs-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                        <i class="bi bi-layout-text-sidebar-reverse"></i> <span>Drop Down</span>
                    </a>
                    <ul class="collapse list-unstyled ps-3" id="dropSubmenu">
                        <li><a href="#">Drop Down 1</a></li>
                        <li><a href="#">Drop Down 2</a></li>
                    </ul>
                </li>

                <hr class="sidebar-divider" />

                <!-- UI Elements -->
                <li><a href="ui_elements/buttons.html"><i class="bi bi-toggle2-on"></i> <span>Buttons</span></a></li>
                <li><a href="ui_elements/charts.html"><i class="bi bi-bar-chart-fill"></i> <span>Charts</span></a></li>
                <li><a href="ui_elements/tables.html"><i class="bi bi-table"></i> <span>Tables</span></a></li>
                <li><a href="ui_elements/icons.html"><i class="bi bi-stars"></i> <span>Icons</span></a></li>

                <hr class="sidebar-divider" />

                <!-- Pages -->
                <li><a href="pages/login.html"><i class="bi bi-box-arrow-in-right"></i> <span>Login</span></a></li>
                <li><a href="pages/register.html"><i class="bi bi-person-plus-fill"></i> <span>Register</span></a></li>
                <li><a href="pages/404.html"><i class="bi bi-exclamation-triangle-fill"></i> <span>404 Page</span></a></li>
            </ul>
        </aside>
           
       

    <div class="main-content" id="main-content">
        <nav class="navbar navbar-light bg-white shadow-sm sticky-top">
            <div class="container-fluid d-flex justify-content-between align-items-center">

                <button id="toggleSidebar" class="btn btn-light">
                    ☰
                </button>




                <div class="d-flex align-items-center gap-3">
                    <input type="text" class="form-control d-none d-md-block" placeholder="Search...">
                    <i class="bi bi-bell fs-5"></i>
                    <div class="dropdown">
                        <button class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown">English</button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#">English</a></li>
                            <li><a class="dropdown-item" href="#">Hindi</a></li>
                        </ul>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center dropdown-toggle"
                                data-bs-toggle="dropdown">
                            <img src="https://devomatemarket.com/favicon.png" class="rounded-circle me-2"
                                 style="width:36px;height:36px;">
                            <div class="text-start">
                                <div class="fw-bold">Ayush Gandhi</div>
                                <small class="text-muted">Admin</small>
                            </div>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#">Profile</a></li>
                            <li><a class="dropdown-item" href="#">Settings</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="#">Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        @RenderBody()
    </div>
</body>

<script src="~/js/AdminUI/adminUi.js" asp-append-version="true">></script>
<script src="~/js/car-pagination.js" asp-append-version="true">></script>
<script src="~/lib/jquery/dist/jquery.min.js" ></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</html>
