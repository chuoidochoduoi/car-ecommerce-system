@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper*, AuthorizingTagHelperApp.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - firstWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <header class="main-header" style="position: absolute; width:100%">
        <nav class="navbar navbar-expand-sm  border-bottom">
            <div class="container-fluid p-3">
                <img src="" alt="">
                <ul class="navbar-nav ">
                    <li class="nav-item ">
                        <a class="nav-link text-white" href="/">Home </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">Financing </a>

                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">Compare </a>

                    </li>
                    <li  class="nav-item">
                        <a id="nav-shop" class="nav-link text-white" href="/shop/shopping">Shop</a>
                    </li>
                    <li class="nav-item vw-25">
                        <a class="nav-link text-white" href="/admin/dashboard">Contact</a>
                    </li>
                    <li class="nav-item vw-25">
                        <a class="nav-link text-white" href="/admin/dashboard">Admin</a>
                    </li>
                </ul>



                <div class="text-center mt-3 fs-5">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="/profile" class="nav-link text-white">
                            Xin chào, <strong>@User.Identity.Name</strong>
                        </a>
                        <a href="/home/logout" class="nav-link text-danger">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            
                        </a>
                    }
                    else
                    {
                        <a href="/home/login" class="text-decoration-none">
                            <i class="bi bi-person-circle "></i>
                        </a>
                    }
                   
                </div>
            </div>
        </nav>

    </header>
    <div class="">
        <main role="main" class="">
            @RenderBody()
        </main>
    </div>

    <footer class="main-footer">
        <div class="container footer-top">

            <div class="footer-col">
                <h3>Car Dealership</h3>
                <p>2715 Ash Dr. San Jose, South Dakota 83475</p>
                <p>(316) 555-0116</p>
            </div>

            <div class="footer-col">
                <h4>Home</h4>
                <p>Home 1</p>
                <p>Home 2</p>
                <p>Home 3</p>
            </div>

            <div class="footer-col">
                <h4>Shop</h4>
                <p>Sports Cars</p>
                <p>Electric</p>
                <p>Hybrid</p>
            </div>

            <div class="footer-col">
                <h4>Company</h4>
                <p>About us</p>
                <p>Our services</p>
                <p>Contact us</p>
            </div>

        </div>

        <div class="footer-bottom">
            © 2025 - firstWeb - All Rights Reserved.
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



<style>
    /* ================= Footer ================= */
    body {
        margin: 0;
        padding: 0;
    }

    .main-footer {
        background: #000;
        color: #ccc;
        padding-top: 80px;
    }

    .footer-top {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 60px;
        padding-bottom: 50px;
        border-bottom: 1px solid #222;
    }

    .footer-col h3,
    .footer-col h4 {
        color: white;
        margin-bottom: 20px;
    }

    .footer-col p {
        margin-bottom: 10px;
        cursor: pointer;
    }

        .footer-col p:hover {
            color: white;
        }

    .footer-bottom {
        text-align: center;
        padding: 25px 0;
        font-size: 14px;
        background: #000;
    }


    .main-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
    }
</style>
<script>
   
    document.addEventListener('DOMContentLoaded',function () {

     
    })


</script>