@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper*, AuthorizingTagHelperApp.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - firstWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/car-pagination.js" asp-append-version="true">></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <header class="main-header" style="position: absolute; width:100%">
        <nav class="navbar navbar-expand-sm  border-bottom">
            <div class="container-fluid p-3">
                <img src="" alt="">
                <ul class="navbar-nav ">
                    <li class="nav-item ">
                        <a class="nav-link text-white" href="/">Home </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">Financing </a>

                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">Compare </a>

                    </li>
                    <li  class="nav-item">
                        <a id="nav-shop" class="nav-link text-white" href="/shop/shopping">Shop</a>
                    </li>
                    <li class="nav-item vw-25">
                        <a class="nav-link text-white" href="/admin/dashboard">Contact</a>
                    </li>
                    <li class="nav-item vw-25">
                        <a class="nav-link text-white" href="/admin/dashboard">Admin</a>
                    </li>
                </ul>



                <div class="text-center mt-3 fs-5">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="/profile" class="nav-link text-white">
                            Xin chào, <strong>@User.Identity.Name</strong>
                        </a>
                        <a href="/home/logout" class="nav-link text-danger">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            
                        </a>
                    }
                    else
                    {
                        <a href="/home/login" class="text-decoration-none">
                            <i class="bi bi-person-circle "></i>
                        </a>
                    }
                   
                </div>
            </div>
        </nav>

    </header>
    <div class="">
        <main role="main" class="">
            @RenderBody()

            <div id="chat-circle" class="btn btn-raised">
                <i class="bi bi-chat-dots-fill"></i>
            </div>

            <div class="chat-box" id="chat-box" style="display: none;">
                <div class="chat-box-header">
                    <span>Hỗ trợ khách hàng</span>
                    <span class="chat-box-toggle"><i class="bi bi-x-lg"></i></span>
                </div>
                <div class="chat-box-body">
                    <div id="chat-messages" style="height: 300px; overflow-y: auto; padding: 10px;">
                    </div>
                </div>
                <div class="chat-input-area">
                    <input type="text" id="chat-input" placeholder="Nhập tin nhắn..." />
                    <button id="chat-submit"><i class="bi bi-send"></i></button>
                </div>
            </div>
        </main>
    </div>

    <footer class="main-footer">
        <div class="container footer-top">

            <div class="footer-col">
                <h3>Car Dealership</h3>
                <p>2715 Ash Dr. San Jose, South Dakota 83475</p>
                <p>(316) 555-0116</p>
            </div>

            <div class="footer-col">
                <h4>Home</h4>
                <p>Home 1</p>
                <p>Home 2</p>
                <p>Home 3</p>
            </div>

            <div class="footer-col">
                <h4>Shop</h4>
                <p>Sports Cars</p>
                <p>Electric</p>
                <p>Hybrid</p>
            </div>

            <div class="footer-col">
                <h4>Company</h4>
                <p>About us</p>
                <p>Our services</p>
                <p>Contact us</p>
            </div>

        </div>

        <div class="footer-bottom">
            © 2025 - firstWeb - All Rights Reserved.
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



<style>


    /* ================= Chat box ================= */


    /* Nút bấm tròn */
    #chat-circle {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #007bff;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0px 3px 16px 0px rgba(0, 0, 0, 0.1), 0 3px 1px -2px rgba(0,0,0,0.2);
        z-index: 9999;
    }

    /* Khung chat Box */
    .chat-box {
        position: fixed;
        bottom: 100px;
        right: 30px;
        width: 350px;
        max-width: 85vw;
        background: white;
        border-top-radius: 10px;
        border: 3px solid black;
        box-shadow: 0px 5px 35px 9px rgba(0,0,0,0.1);
        z-index: 10000;
        overflow: hidden;
    }

    .chat-box-header {
        background: #333333;
        padding: 15px;
        color: white;
        display: flex;
        justify-content: space-between;
    }

    .chat-box-toggle {
        cursor: pointer;
    }

    .chat-input-area {
        border-top: 5px solid #eee;
        display: flex;
        padding: 10px;
    }

    #chat-input {
        flex: 1;
        border: none;
        outline: none;
    }

    #chat-submit {
        background: none;
        border: none;
        color: #007bff;
        font-size: 20px;
    }


    /* chat message*/
    /* Container chứa các tin nhắn */
    #chat-messages {
        display: flex;
        flex-direction: column;
        gap: 12px; /* Khoảng cách giữa các tin nhắn */
    }

    /* Style chung cho mỗi khối tin nhắn */
    .msg-wrapper {
        display: flex;
        flex-direction: column;
        max-width: 80%;
    }

    .user-wrapper {
        align-self: flex-end;
        align-items: flex-end;
    }

        .user-wrapper .msg-content {
            background-color: #007bff;
            color: white;
            padding: 8px 12px;
            border-radius: 15px 15px 2px 15px; /* Bo góc kiểu hiện đại */
        }

    /* Tin nhắn của AI hoặc ADMIN (Bên trái) */
    .ai-wrapper {
        align-self: flex-start;
        align-items: flex-start;
    }

        .ai-wrapper .msg-content {
            background-color: #f1f0f0;
            color: #333;
            padding: 8px 12px;
            border-radius: 15px 15px 15px 2px;
        }

    /* Style cho tên và thời gian */
    .msg-meta {
        font-size: 11px;
        color: #888;
        margin-bottom: 2px;
    }

    /* ================= Footer ================= */
    body {
        margin: 0;
        padding: 0;
    }

    .main-footer {
        background: #000;
        color: #ccc;
        padding-top: 80px;
    }

    .footer-top {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 60px;
        padding-bottom: 50px;
        border-bottom: 1px solid #222;
    }

    .footer-col h3,
    .footer-col h4 {
        color: white;
        margin-bottom: 20px;
    }

    .footer-col p {
        margin-bottom: 10px;
        cursor: pointer;
    }

        .footer-col p:hover {
            color: white;
        }

    .footer-bottom {
        text-align: center;
        padding: 25px 0;
        font-size: 14px;
        background: #000;
    }


    .main-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
    }



</style>
<script>
  
        // 1. Khai báo biến ra NGOÀI cùng để các hàm đều thấy
        let connection = null;
        let conversationId = null;

        document.addEventListener('DOMContentLoaded', function () {
            const chatCircle = document.getElementById('chat-circle');
        const chatBox = document.getElementById('chat-box');
        const chatToggle = document.querySelector('.chat-box-toggle');
        const msgList = document.getElementById("chat-messages");
        const input = document.getElementById("chat-input");
        const sendBtn = document.getElementById("chat-submit");

              // Mở / đóng chat
        chatCircle.addEventListener('click', () => {
            chatBox.style.display = 'block';
        chatCircle.style.display = 'none';
        });

        chatToggle.addEventListener('click', () => {
            chatBox.style.display = 'none';
        chatCircle.style.display = 'flex';
        });
        // 2. Khởi tạo kết nối (Gán vào biến ở trên)
        connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

        connection.on("ReceiveMessage", function (displayName, message, createdAt) {
            const msgHtml = `
            <div class="msg-wrapper user-wrapper">
                <span class="msg-meta">${createdAt} - ${displayName}</span>
                <div class="msg-content">${message}</div>
            </div>`;

            const msgList = document.getElementById("chat-messages");
            msgList.innerHTML += msgHtml;
            msgList.scrollTop = msgList.scrollHeight;
        });

        connection.on("ReceiveChatMessage", function (chatMessage) {
            const msgHtml = `
            <div class="msg-wrapper ai-msg ai-wrapper">
                <span class="msg-meta">Trợ lý AI</span>
                <div class="msg-content">${chatMessage}</div>
            </div>`;

            const msgList = document.getElementById("chat-messages");
            msgList.innerHTML += msgHtml;
            msgList.scrollTop = msgList.scrollHeight;
        });

        // 4. Start connection
        connection.start()
            
        // 5. Logic gửi tin nhắn (Nằm trong này để lấy được các biến DOM)
        sendBtn.addEventListener("click", function () {

            const message = input.value;

            connection.invoke("SendMessage",  0, message)
                .then(id => {
                    console.log("Gọi thành công!");
                    conversationId = id; // Lưu lại conversationId trả về từ server
                })
                .catch(err => {
                    console.error("Lỗi gọi Hub:", err.toString());
                    alert("❌ Lỗi gọi Hub:\n" + err.toString());
                });
        });
        });
</script>
