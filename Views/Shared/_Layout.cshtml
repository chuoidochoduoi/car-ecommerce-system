@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper*, AuthorizingTagHelperApp.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - firstWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <header class=""  style="position: absolute; width:100%">
        <nav class="navbar navbar-expand-sm  border-bottom">
            <div class="container-fluid p-3">
                <img src="" alt="">
                <ul class="navbar-nav ">
                    <li class="nav-item ">
                        <a class="nav-link text-white" href="#">who we are</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">dddd</a>

                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#">Some Demo</a>

                    </li>
                    <li  class="nav-item">
                        <a id="nav-shop" class="nav-link text-white" href="/shop/shopping">Shop</a>
                    </li>
                    <li class="nav-item vw-25">
                        <a class="nav-link text-white" href="/admin/dashboard">Admin</a>
                    </li>
                </ul>



                <div class="text-center mt-3 fs-5">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="/profile" class="nav-link text-white">
                            Xin chào, <strong>@User.Identity.Name</strong>
                        </a>
                        <a href="/home/logout" class="nav-link text-danger">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            
                        </a>
                    }
                    else
                    {
                        <a href="/home/login" class="text-decoration-none">
                            <i class="bi bi-person-circle "></i>
                        </a>
                    }
                   
                </div>
            </div>
        </nav>

    </header>
    <div class="">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - firstWeb - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
   
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
   
    document.addEventListener('DOMContentLoaded',function () {

     
    })


</script>