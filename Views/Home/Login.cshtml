@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Car Store - Login</title>

    <style>
            body {
            margin: 0;

            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
            height: 100vh;
                display: flex;
            justify-content: center;

            align-items: center;
        }

        .login-card {
            background: white;
            width: 380px;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            text-align: center;
        }

        .login-card h2 {
            margin-bottom: 25px;
            color: #2c5364;
        }

        .login-card input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 14px;
        }

        .login-card input:focus {
            outline: none;
            border-color: #2c5364;
            box-shadow: 0 0 5px #2c5364;
        }

        .login-btn {
            background: #2c5364;
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            border-radius: 8px;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
        }

        .login-btn:hover {
            background: #203a43;
        }

        .brand {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 10px;
            color: #0f2027;
        }

        .message-success {
            color: green;
            margin-top: 10px;
        }

        .message-error {
            color: red;
            margin-top: 10px;
        }

        .register-link {
            margin-top: 15px;
            font-size: 14px;
        }

        .register-link a {
            text-decoration: none;
            color: #2c5364;
            font-weight: bold;
        }

    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand"> Luxury Car Store</div>
        <h2>Login</h2>

        <form asp-controller="Home" asp-action="Login" method="post">


            <input type="text" name="Username" placeholder="Enter username" required />

            <input type="password" name="Password" placeholder="Enter password" required />

            <button type="submit" class="login-btn">Login</button>

            @if (TempData["Success"] != null)
            {
                <div class="message-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="message-error">
                    @TempData["Error"]
                </div>
            }

        </form>

        <div class="register-link">
            Don't have an account?
            <a asp-controller="Home" asp-action="Register">Register</a>
        </div>

    </div>

</body>
</html>


