<div class="container m-1 text-primary">
    <p>Register</p>

    @model ManageCars.Models.ViewModel.RegisterViewModel
    <form asp-controller="home" asp-action="register" method="post">
        <label asp-for="AccountName">AccountName</label>
        <input asp-for="AccountName" />

        <label asp-for="AccountPassword">Password</label>
        <input asp-for="AccountPassword" type="password" />

        <label asp-for="ReAccountPassword">Re-Password</label>
        <input asp-for="ReAccountPassword" type="password" />

        <input type="submit" value="Login" />
    </form>

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div>@ViewBag.ErrorMessage</div>
    }
    
</div>