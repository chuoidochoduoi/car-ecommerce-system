@{
	Layout = "_AdminLayout";
}









	<div class="container-fluid py-4">

		<!-- Order List Section -->
		<div class="chart-box mt-4 p-4 rounded-4 shadow-sm" style="background:#fff;">
			<div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
				<h5 class="fw-semibold m-0 text-dark">📋 Order Lists</h5>
				<div class="d-flex flex-wrap gap-2">
				<select id="filter-sortby" class="form-select form-select-sm" style="width:auto;">
						<option>Filter By</option>
						<option>Date</option>
						<option>Status</option>
					</select>
				<select id="filter-date" class="form-select form-select-sm" style="width:auto;">
						<option>Date</option>
						<option>Newest</option>
						<option>Oldest</option>
					</select>

				<select id="filter-status" class="form-select form-select-sm">
					<option value="">Order Status</option>
					<option value="0">New</option>

					<option value="1">Contacted</option>
					<option value="5">Completed</option>
					<option value="2">Deposit</option>
					<option value="3">Viewing Scheduled</option>
					<option value="4">Negotiating</option>
					<option value="6">Cancelled</option>
				</select>
				<button id="reset-filter" class="btn btn-link text-danger fw-semibold text-decoration-none">
						🔁 Reset Filter
					</button>
				</div>
			</div>

			<div class="table-responsive">
				<table class="table align-middle mb-0">
					<thead style="background-color:#f1f4f9;" class="text-secondary small text-uppercase">
						<tr>
							<th>ID</th>
							<th>Name</th>
							<th>CarId</th>
							<th>Quantity</th>
							<th>Date</th>
							<th>Status</th>
							<th>Meeting</th>
							<th>Action</th>
						</tr>
					</thead>
					<tbody id="order-list-table">
					
					</tbody>
				</table>
			</div>

			<div class="d-flex justify-content-between align-items-center mt-3 text-secondary small">
				<span class="paging-info"></span>

				<ul class="pagination pagination-sm mb-0 meeting-pagination">
					<li class="page-item">
						<a class="page-link prev" href="#">‹</a>
					</li>

					<!-- page numbers -->

					<li class="page-item">
						<a class="page-link next" href="#">›</a>
					</li>
				</ul>
			</div>
		</div>


		<!--Model contact -->
		<div id="contact-customer" class="modal"  tabindex="-1" role="dialog">
			<div class="modal-dialog" role="document">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Customer Information</h5>

						<button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
					<div id="modal-customer-infor" class="modal-body">
						<div class="customer-summary p-3 mb-4 bg-light rounded border">
							<h4 class="text-primary mb-3"><i class="bi bi-person-circle"></i> Customer Information</h4>
							<div class="row">
								<div class="col-md-6">
									<p><strong>Name:</strong> <span id="name" class="text-dark"></span></p>
									<p><strong>Phone:</strong> <span id="phone-number" class="text-dark"></span></p>
								</div>
								<div class="col-md-6">
									<p><strong>Email:</strong> <span id="email" class="text-dark"></span></p>
								</div>
							</div>
							<div class="mt-2">
								<strong><i class="bi bi-sticky"></i> Note from Customer:</strong>
								<p id="message" class="text-muted fst-italic shadow-sm p-2 bg-white rounded"></p>
							</div>
						</div>

						<hr />

						<div class="meeting-form mt-4 d-none">
							<h4 class="mb-3 text-success"><i class="bi bi-calendar-event"></i> Schedule a Meeting</h4>

							@model Meeting
							<form id="Meeting-add-form"  class="row g-3">
								<input type="hidden"  name="OrderId" id="hidden-order-id" value="" />

								<div class="col-12">
									<label class="form-label fw-bold">Title</label>
									<input asp-for="Title" class="form-control" placeholder="e.g., Car Viewing with Customer" />
								</div>

								<div class="col-md-12">
									<label class="form-label fw-bold">Start Time</label>
									<input asp-for="StartTime" type="datetime-local" class="form-control" />
								</div>
								
							

								<div class="col-12">
									<label class="form-label fw-bold">Location</label>
									<input asp-for="Location" class="form-control" placeholder="Showroom or Online Link" />
								</div>

								<div class="col-md-12">
									<label class="form-label fw-bold">Description</label>
									<textarea asp-for="Description" class="form-control" rows="3" placeholder="More details..."></textarea>
								</div>

							
								<div class="col-12 text-end mt-4">
									<button type="submit" class="btn btn-success px-4">
										<i class="bi bi-save"></i> Save Meeting
									</button>
								</div>
							</form>
						</div> 


						<div id="meetingDetail" class="mt-4">

							<div class="card shadow border-0">

								<div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
									<h5 class="mb-0">
										<i class="bi bi-calendar-check"></i> Meeting Detail
									</h5>

									<span id="meet-status" class="badge bg-primary">
										
									</span>
								</div>

								<div class="card-body">

									<div class="row mt-3">
										<div class="col-md-6">
											<p>
												<i class="bi bi-clock text-secondary"></i>
												<strong>Start Time:</strong><br />
												<span id="meet-time"></span>
											</p>
										</div>

										<div class="col-md-6">
											<p>
												<i class="bi bi-geo-alt text-danger"></i>
												<strong>Location:</strong><br />
												<span id="meet-location"></span>
											</p>
										</div>
									</div>

									<div class="mt-3">
										<strong>
											<i class="bi bi-card-text text-info"></i>
											Description:
										</strong>

										<div id="meet-Description" class="p-3 bg-light rounded mt-2">
										</div>
									</div>


									<div class="mt-4 text-end" id="meeting-actions">
										<button id="btn-complete" class="btn btn-success me-2">
											<i class="bi bi-check-circle"></i>
											Hoàn thành
										</button>

										<button id="btn-cancel" class="btn btn-danger">
											<i class="bi bi-x-circle"></i>
											Hủy
										</button>
									</div>

								</div>
							</div>

						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-primary">Save changes</button>
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
					</div>
				</div>
			</div>
		</div>

	<!--Model contact -->
		<div id="update-order" class="modal"  tabindex="-1" role="dialog">
			<div class="modal-dialog" role="document">
				<div class="modal-content">

					<div class="modal-header bg-primary text-white">
						<h5 class="modal-title">Update Order</h5>
						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
					</div>

					<div class="modal-body">

						<input type="hidden" id="update-order-id" />

						<div class="row">

							<!-- Status -->
							<div class="col-md-6 mb-3">
								<label class="form-label">Status</label>
								<select id="update-status" class="form-select">
									<option value="2">Deposit</option>
									<option value="3">Viewing Scheduled</option>
									<option value="4">Negotiating</option>
									<option value="5">Completed</option>
									<option value="6">Cancelled</option>
								</select>
							</div>

							<!-- Assigned To -->
							<div class="col-md-6 mb-3">
								<label class="form-label">Assigned To</label>
								<input type="text" id="update-assigned" class="form-control" placeholder="Sales name" />
							</div>

							<!-- Final Price -->
							<div class="col-md-6 mb-3">
								<label class="form-label">Final Price</label>
								<input type="number" id="update-finalprice" class="form-control" />
							</div>

							<!-- Deposit -->
							<div class="col-md-6 mb-3">
								<label class="form-label">Deposit Amount</label>
								<input type="number" id="update-deposit" class="form-control" />
							</div>

							<!-- Payment Method -->
							<div class="col-md-6 mb-3">
								<label class="form-label">Payment Method</label>
								<select id="update-payment" class="form-select">
									<option value="">-- Select --</option>
									<option value="Cash">Cash</option>
									<option value="Bank Transfer">Bank Transfer</option>
									<option value="Installment">Installment</option>
								</select>
							</div>

							<!-- Completion Note -->
							<div class="col-12 mb-3">
								<label class="form-label">Note</label>
								<textarea id="update-note" class="form-control" rows="3"></textarea>
							</div>

						</div>

					</div>
					<div class="modal-footer">
						<button id="save-update" type="button" class="btn btn-primary">Save changes</button>
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
					</div>
				</div>
			</div>
		</div>

		<style>
			.table tbody tr:hover {
				background-color: #f9fbfd;
				transition: 0.2s ease;
			}

			.form-select-sm,
			.btn {
				font-size: 0.875rem;
			}
		</style>


		<!-- Footer -->
		<footer class="footer text-center py-3">
			<div class="container">
				<span>Designed by <strong>Devomate</strong></span> |
				<span>&copy; 2025 All Rights Reserved</span>
			</div>
		</footer>


	</div>






<script>
	const ctx = document.getElementById('salesChart');

	// new Chart(ctx, {
	// 	type: 'line',
	// 	data: {
	// 		labels: ['5k', '10k', '15k', '20k', '25k', '30k', '35k', '40k', '45k', '50k', '55k', '60k'],
	// 		datasets: [{
	// 			label: 'Sales',
	// 			data: [20, 40, 35, 65, 45, 55, 35, 70, 50, 60, 55, 58],
	// 			borderColor: '#0d6efd',
	// 			backgroundColor: 'rgba(13,110,253,0.1)',
	// 			tension: 0.4,
	// 			fill: true,
	// 			pointBackgroundColor: '#0d6efd',
	// 			pointRadius: 4
	// 		}]
	// 	},
	// 	options: {
	// 		responsive: true,
	// 		maintainAspectRatio: false, important for fixed height
	// 		scales: {
	// 			y: {
	// 				beginAtZero: true,
	// 				ticks: {
	// 					stepSize: 20,
	// 					callback: value => value + '%'
	// 				},
	// 				grid: { color: 'rgba(0,0,0,0.05)' }
	// 			},
	// 			x: {
	// 				grid: { display: false }
	// 			}
	// 		},
	// 		plugins: {
	// 			legend: { display: false },
	// 			tooltip: {
	// 				backgroundColor: '#0d6efd',
	// 				titleColor: '#fff',
	// 				bodyColor: '#fff',
	// 				cornerRadius: 6
	// 			}
	// 		}
	// 	}
	// });


	document.addEventListener('DOMContentLoaded', function () {
		console.log("carlist"); // nên thấy dòng này nếu không có lỗi JS
		OrderList(1);



	});




	document.querySelectorAll('select').forEach(select => {
		select.addEventListener('change', () => OrderList(1));
	});



	document.querySelector('#reset-filter').addEventListener('click', () => {

		document.querySelector('#filter-sortby').selectedIndex = 0;
		document.querySelector('#filter-date').selectedIndex = 0;
		document.querySelector('#filter-status').selectedIndex = 0;

		OrderList(1);
	});

	

	function OrderList(page) {

		const sortBy = document.querySelector('#filter-sortby').value;
		const sortDate = document.querySelector('#filter-date').value;
		const status = document.querySelector('#filter-status').value;
		
		fetch('/order/list', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				_pageNumber: page,
				_pageSize: 6,
				sortBy: sortBy,
				sortDate: sortDate,
				status: status
			})
		})
			.then(response => response.json())
			.then(data => {

				const table = document.querySelector('#order-list-table')
				table.innerHTML = ``;
				data.orders.forEach(order => {
					const row = table.insertRow(); 
					row.innerHTML = `
					<td>${order.id}</td>
					<td>${order.customerName}</td>
					<td>${order.carId}</td>
					<td>${order.quantity}</td>
					<td>${order.createdDate}</td>
					<td><span class="badge bg-info">${order.status}</span></td>
										<td>${!order?.lastmeeting ? '—'
							: order.lastmeeting.status === 'Scheduled' ? '📅✔'
								: order.lastmeeting.status === 'Completed' ? '📦✔'
									: order.lastmeeting.status === 'Canceled' ? '📅➕'
								: '—'}
					</td >

					<td>
						<button class="model-order-btn btn btn-primary btn-sm" type="button"
									data-bs-toggle="modal" data-bs-target="#contact-customer"
								value="${order.id}">Contact</button>

								<button  class="model-update-order btn btn-primary btn-sm" type="button"
											data-bs-toggle="modal" data-bs-target="#update-order"
									value="${order.id}">Update</button>
						
					</td>	
					`; 


				});
				const buttons = document.querySelectorAll('.model-order-btn');
				buttons.forEach(btn => {
					btn.addEventListener('click', function () {
						const orderId = this.value;
						console.log("Đang lấy thông tin cho đơn hàng ID:", orderId);

						getCustomerInfor(orderId);
					});
				});

				const buttonsUpdate = document.querySelectorAll('.model-update-order');
				buttonsUpdate.forEach(btn => {
					btn.addEventListener('click', function () {
						const orderId = this.value;
						console.log("Đang lấy thông tin cho đơn hàng ID:", orderId);

						document.querySelector('#update-order-id').value = orderId


					});
				});


				document.querySelector("#save-update").addEventListener('click', function(){
					submitUpdateOrder()

				})


				createPagination({
					containerSelector: '.meeting-pagination',
					infoSelector: '.paging-info',
					currentPage: data.currentPage,
					pageSize: 6,
					totalItems: data.totalItems,
					onPageChange: p => OrderList(p)
				});



			})
			.catch(error => console.error('Error fetching car data:', error));
	}





	function getCustomerInfor(orderId) {

		fetch('/order/inform', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json'
			},
			body: JSON.stringify(orderId)
		})
			.then(response => response.json())
			.then(data => {
				const model = document.querySelector('#modal-customer-infor')

				model.querySelector('#name').textContent = "name: "+ data.orders.customerName
				model.querySelector('#phone-number').textContent ="Phone: " +data.orders.phoneNumber

				model.querySelector('#email').textContent = "Email: " + data.orders.email

				model.querySelector('#message').textContent =  data.orders.message
				model.querySelector('#hidden-order-id').value = orderId

				const form = model.querySelector('.meeting-form')

				const meetingModel = model.querySelector('#meetingDetail')


				form.classList.add("d-none");

				meetingModel.classList.add("d-none")


				const meetingsubmit = document.querySelector("#btn-complete")

				meetingsubmit.addEventListener('click', function () {
					CompleteMeeting(data.meetdetail.id)
				});

				const meetingcancel = document.querySelector("#btn-cancel")

				meetingsubmit.classList.remove("d-none")
				meetingcancel.classList.remove("d-none")


				meetingcancel.addEventListener('click', function () {

					CancelMeeting(data.meetdetail.id)
				});



				if (data.meetdetail.status !== "Scheduled") {
					meetingsubmit.classList.add("d-none")
					meetingcancel.classList.add("d-none")

				}
				console.log(data.meetdetail.status)


				if (!data.isMeeting) {

					form.classList.remove("d-none");


				}else{
					meetingModel.classList.remove("d-none");
					model.querySelector('#meet-time').textContent = data.meetdetail.startTime;
					model.querySelector('#meet-location').textContent = data.meetdetail.location;
					model.querySelector('#meet-Description').textContent = data.meetdetail.description;

					model.querySelector('#meet-status').textContent = data.meetdetail.status;

				}
				
				CreateMeeting()

			})
			.catch(error => console.error('Error fetching car data:', error));
	}



	
	const connection = new signalR.HubConnectionBuilder()
	.withUrl('/carHub')
	.withAutomaticReconnect()
	.build();

	connection.on("ReceiveOrderNotification", function (order) {
		console.log("Có order mới:", order);
		OrderList(1);
	});


	connection.start()
	.then(() => console.log('SignalR Connected'))
	.catch(err => console.error('SignalR Connection Error:', err));



	function CompleteMeeting(Id) {

		

		fetch('/meeting/complete', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json'
			},
			body: JSON.stringify(Id)
		}).then(response => response.json())
		.then(data => {


				if (data.success) {
									Swal.fire({
										title: "Good job!",
										text: "complete ",
										icon: "success"
									});
								}
								else {
									Swal.fire({
										icon: "error",
										title: "Oops...",
									text: "cant complete!"
									});
								}

			

					
		})
			.catch(error => console.error('Error fetching faild complete:', error));


		
	}


	function CancelMeeting(Id) {


		fetch('/meeting/cancel', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json'
			},
			body: JSON.stringify(Id)
		}).then(response => response.json())
			.then(data => {
				if (data.success) {
					Swal.fire({
						title: "Good job!",
						text: "cancel ",
						icon: "success"
					});
				}
				else {
					Swal.fire({
						icon: "error",
						title: "Oops...",
						text: "cant cancel!"
					});
				}
			})
			.catch(error => console.error('Error fetching faild complete:', error));



	}
	


	function CreateMeeting() {

		document.getElementById("Meeting-add-form").addEventListener("submit", function (event) {
			event.preventDefault(); // Ngăn chặn hành vi mặc định của form

			const formData = new FormData(this);

			
			Swal.fire({
				title: "Are you sure?",
				showCancelButton: true,
				confirmButtonText: "Yes",
			}).then((result) => {
				if (result.isConfirmed) {

					fetch('/meeting/add', {
						method: 'post',
						body: formData

					}).then(response => response.json())
						.then(a => {

							if (a.success) {
								Swal.fire({
									title: "Good job!",
									text: "Create success",
									icon: "success"
								});
							}
							else {
								Swal.fire({
									icon: "error",
									title: "Oops...",
									text: "it already have meeting!"
								});
							}
							
						})
						.catch(error => {
							console.error('Error fetching user details:', error);
						});

				}
			});




		});


		
	}


	
	function submitUpdateOrder() {

		const data = {
			id: document.getElementById('update-order-id').value,
			status: document.getElementById('update-status').value,
			assignedTo: document.getElementById('update-assigned').value,
			finalPrice: document.getElementById('update-finalprice').value,
			depositAmount: document.getElementById('update-deposit').value,
			paymentMethod: document.getElementById('update-payment').value,
			completionNote: document.getElementById('update-note').value
		};

		fetch('/order/process', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		})
			.then(res => res.json())
			.then(result => {
				

				if (result.success) {
					Swal.fire({
						title: "Good job!",
						text: "up success",
						icon: "success"
					});
					OrderList(1);
					bootstrap.Modal.getInstance(document.getElementById('updateOrderModal')).hide();
				}
			});
	}




</script>