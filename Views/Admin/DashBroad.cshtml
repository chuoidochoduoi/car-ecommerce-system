@{
    Layout = "_AdminLayout";
}


    <div class="container-fluid py-4">

        <h3><b>Dashboard</b></h3>

        <div class="row g-2 mb-4">

            <!-- Total User -->
            <div class="col-md-3">
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5>Total User</h5>
                            <h3 id="totalUser"></h3>
                            <span class="stat-up">⬆ 8.5% Up from yesterday</span>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px; height:50px; background-color:#e8f0ff;">
                            <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" width="25">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Order -->
            <div class="col-md-3">
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5>Total Order</h5>
                            <h3 id="totalOrder">0</h3>
                            <span class="stat-normal">⬆ 1.3% Up from past week</span>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px; height:50px; background-color:#fff6e5;">
                            <img src="https://cdn-icons-png.flaticon.com/512/1524/1524855.png" width="25">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Sales -->
            <div class="col-md-3">
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5>Total Sales</h5>
                            <h3 id="totalSales">0</h3>
                            <span class="stat-down">⬇ 4.3% Down from yesterday</span>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px; height:50px; background-color:#e8fff1;">
                            <img src="https://cdn-icons-png.flaticon.com/512/2331/2331941.png" width="25">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Pending -->
            <div class="col-md-3">
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5>Total Pending</h5>
                            <h3 id="totalPending">0</h3>        
                            <span class="stat-up">⬆ 1.8% Up from yesterday</span>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px; height:50px; background-color:#ffeaea;">
                            <img src="https://cdn-icons-png.flaticon.com/512/1828/1828911.png" width="25">
                        </div>
                    </div>
                </div>
            </div>

        </div>



        <!-- Chart Section -->
        <div class="chart-box mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="m-0 fw-semibold">Sales Details</h5>
                <select class="form-select form-select-sm" style="width:auto;">
                    <option>October</option>
                    <option>September</option>
                    <option>August</option>
                </select>
            </div>

            <!-- Fixed height wrapper -->
            <div style="height: 300px;">
                <canvas id="salesChart"></canvas>
            </div>
        </div>







        <!-- Product Table Section -->
        <div class="chart-box mt-4 p-4 rounded-4 shadow-sm" style="background:#fff;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="m-0 fw-semibold text-dark">🛍️ Product Sales Overview</h5>
                <input type="text" id="searchInput"
                       class="form-control form-control-sm shadow-none border-0 rounded-3"
                       placeholder="🔍 Search Product..." style="max-width: 250px; background-color:#f1f4f9;">
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: #f1f4f9;">
                        <tr class="text-uppercase text-secondary small fw-semibold">
                            <th scope="col" class="ps-3">Product</th>
                            <th scope="col">Discount Price</th>
                            <th scope="col">MRP Price</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody id="productTable">
                        <tr class="border-bottom">
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <img src="https://cdn-icons-png.flaticon.com/512/1061/1061349.png" alt="product"
                                         width="42" class="me-3 rounded-3 shadow-sm">
                                    <span class="fw-semibold text-dark">Wireless Headphones</span>
                                </div>
                            </td>
                            <td class="fw-semibold text-success">₹1,499</td>
                            <td class="text-muted"><s>₹2,499</s></td>
                            <td>
                                <span class="badge bg-success-subtle text-success fw-semibold px-3 py-2 rounded-pill">Active</span>
                            </td>
                        </tr>

                        <tr class="border-bottom">
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <img src="https://cdn-icons-png.flaticon.com/512/679/679922.png" alt="product"
                                         width="42" class="me-3 rounded-3 shadow-sm">
                                    <span class="fw-semibold text-dark">Smart Watch</span>
                                </div>
                            </td>
                            <td class="fw-semibold text-success">₹2,999</td>
                            <td class="text-muted"><s>₹3,999</s></td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary fw-semibold px-3 py-2 rounded-pill">Delivered</span>
                            </td>
                        </tr>

                        <tr class="border-bottom">
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <img src="https://cdn-icons-png.flaticon.com/512/2738/2738898.png" alt="product"
                                         width="42" class="me-3 rounded-3 shadow-sm">
                                    <span class="fw-semibold text-dark">Bluetooth Speaker</span>
                                </div>
                            </td>
                            <td class="fw-semibold text-success">₹899</td>
                            <td class="text-muted"><s>₹1,499</s></td>
                            <td>
                                <span class="badge bg-danger-subtle text-danger fw-semibold px-3 py-2 rounded-pill">Cancelled</span>
                            </td>
                        </tr>

                        <tr>
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <img src="https://cdn-icons-png.flaticon.com/512/270/270798.png" alt="product"
                                         width="42" class="me-3 rounded-3 shadow-sm">
                                    <span class="fw-semibold text-dark">Gaming Mouse</span>
                                </div>
                            </td>
                            <td class="fw-semibold text-success">₹1,199</td>
                            <td class="text-muted"><s>₹1,699</s></td>
                            <td>
                                <span class="badge bg-warning-subtle text-warning fw-semibold px-3 py-2 rounded-pill">Complete</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Search Script -->
        <script>
            document.getElementById('searchInput').addEventListener('keyup', function () {
                const searchValue = this.value.toLowerCase();
                const rows = document.querySelectorAll('#productTable tr');
                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(searchValue) ? '' : 'none';
                });
            });
        </script>

        <style>
            .table tbody tr:hover {
                background-color: #f8fafc !important;
                transition: 0.2s ease;
            }
        </style>


        <!-- Footer -->
        <footer class="footer text-center py-3">
            <div class="container">
                <span>Designed by <strong>Devomate</strong></span> |
                <span>&copy; 2025 All Rights Reserved</span>
            </div>
        </footer>

    </div>





<script>




    document.addEventListener('DOMContentLoaded', function () {
        updateStats()
        fetchChartData()
    });


    function fetchChartData() {
        fetch('/admin/monthly-sales')
            .then(res => res.json())
            .then(data => {

                const labels = data.map(x => 'T' + x.month);
                const values = data.map(x => x.total);

                renderChart(labels, values);

            });
		
        }
    function renderChart(labels, values) {

        const ctx = document.getElementById('salesChart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Monthly Sales',
                    data: values,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13,110,253,0.1)',
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#0d6efd',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: value => value.toLocaleString() + ' ₹'
                        }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    }

    function updateStats() {


        fetch('/admin/stats', {
            method: 'Get',
            headers: {
                'Content-Type': 'application/json'
            }
        })
			.then(response => response.json())
			.then(data => {
                document.getElementById('totalUser').textContent = data.countUser.toLocaleString();
                document.getElementById('totalOrder').textContent = data.countOrder.toLocaleString();
                document.getElementById('totalSales').textContent = '₹' + data.countSales.toLocaleString();
                document.getElementById('totalPending').textContent = data.countPending.toLocaleString();
			})
			.catch(error => console.error('Error fetching stats:', error));

		
	}


</script>


