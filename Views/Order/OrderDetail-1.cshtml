@{
}

@model string

<div>
	<p>aaa + @Model</p>
</div>
<div>
	<div class="orderDetail"> </div>
	<div class="user"></div>

	<div class="car"></div>

</div>

	<form method="post" class="emailSend">
	
	<input class="emailInput" type="text" name="To" value="" readonly/>
	<input type="text" name="Subject" value="" />
	<input type="text" name="Body" value="" />

	<button type="submit" class="btn btn-primary">Send email</button>
	</form>

<script>

	document.addEventListener('DOMContentLoaded', function () {
		console.log("order detail"); // nên thấy dòng này nếu không có lỗi JS
		getOrderIdFromUrl()

	});


	function getOrderIdFromUrl() {
		
	fetch('/order/OrderInformation', {
		method: 'POST',
		headers: {
			'Content-Type': 'application/json'
		},
		body: JSON.stringify("@Model")
	})
		.then(response => response.json())
		.then(a => {

				document.querySelector('.orderDetail').innerHTML += `
												<p>Order ID: ${a.order.id}</p>
												<p>Order Date: ${new Date(a.order.orderDate).toLocaleDateString()}</p>
												<p>Order Status: ${a.order.status}</p>
												<hr />
											`;

				document.querySelector('.user').innerHTML += `
											<p>User Name: ${a.user.userName}</p>
											<p>User Email: ${a.user.emaill}</p>
											<p>User Phone: ${a.user.phone}</p>
											<p>User Address: ${a.user.address}</p>
											<hr />
										`;

				document.querySelector('.car').innerHTML += `
											<p>Car Name: ${a.car.name}</p>
											<p>Car Type: ${a.car.model}</p>
											<p>Car Year: ${a.car.year}</p>
											<p>Car Price: ${a.car.price}</p>
											<p>Car Description: ${a.car.description}</p>
											<p>Car Category: ${a.car.categoryName}</p>
											<hr />
										`;

				document.querySelector('.emailInput').value = a.user.emaill

			})
		.catch(error => {
			console.error('Error fetching user details:', error);
		});
	}

	 
	document.querySelector('.emailSend').addEventListener('submit', function(event) {
		event.preventDefault(); // Ngăn chặn hành vi mặc định của form
		const formData = new FormData(this);
		SendEmail(formData);
	});

	function SendEmail(formData) {

		fetch('/manager/sendemail', {
			method: 'POST',
			body: formData
		})
			.then(response => response.json())
			.then(data => {
				if (data.success) {
					alert(data.message);
				} else {
					alert(data.message);
				}
			})
			.catch(error => {
				console.error('Error sending email:', error);
				alert('An error occurred while sending the email.');
			});

	}

</script>