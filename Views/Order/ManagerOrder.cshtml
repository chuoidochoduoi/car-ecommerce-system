@{
}

<div>
    <h2 class="text-primary">Manager Order</h2>
	<hr />
	
	<div class="row">
		<div class="col-md-12">
			<table class="table table-bordered">
				<thead>
					<tr>
						<th>Order ID</th>
						<th>Car id</th>
						<th>Customer id</th>
						<th>Order Date</th>
						<th>Status</th>
					</tr>
				</thead>
				<tbody class="">
					
				</tbody>
			</table>
			<div class="pagination pagin">

			</div>
		</div>
	</div>
	<ul class="pagination">
		
	</ul>
</div>
<script>
	document.addEventListener('DOMContentLoaded', function () {
		console.log("manager order"); // nên thấy dòng này nếu không có lỗi JS
		OrderList(1)
		
	});

	function OrderList(page) {
		// Ensure the document is fully loaded before executing scripts
		// JavaScript to handle the dynamic loading of order data and actions
		// Fetch order data from the server and populate the table
		fetch('/order/OrderList', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json'
			},
			body: JSON.stringify({ _pageNumber: page, _pageSize: 6 })
		})
			.then(response => response.json())
			.then(data => {
				const tableBody = document.querySelector('tbody');
				tableBody.innerHTML = ''; // Clear existing rows

				data.orders.forEach(order => {
					tableBody.innerHTML += `
						<tr>
									<td>${order.id}</td>
									<td>${order.carId}</td>
									<td>${order.userId}</td>
									<td>${new Date(order.orderDate).toLocaleDateString()}</td>
									<td>${order.status}</td>
									<td>${order.quantity}</td>
									<td>${order.totalPrice}</td>
							<td><button class="orderDetails" value="${order.id}">View Detail</button></td>
						</tr>
					`;
				});
				pagePagin(data.currentPage,data.totalPage)
				document.querySelectorAll('.orderDetails').forEach(button => {
					button.addEventListener('click', function () {
						alert(this.value);
						orderDetail(this.value);
					});
				});
			})
			.catch(error => console.error('Error fetching orders:', error));
	}


	function pagePagin(currentPage, totalPage){
		var orderPargin = document.querySelectorAll(".pagin") 
		orderPargin.innerHTML = ''

		for (let i = 1; i <= totalPage; i++) {

			orderPargin.innerHTML = `
				<li class="page-item pageorder ${i == currentPage ? 'active' : ''}">
				<a class='"page-link" href="/order/orderlist" data-page="${i}"'></a>
			</li>
			`;
		}
	}

	document.querySelectorAll(".pageorder a").forEach(link => {
		link.addEventListener("click", e => {
			e.preventDefault();
			const page = link.dataset.page;
			console.log("trang hien tai " + page);
			OrderList(page);
		})

	});

	
	function orderDetail(id) {
		window.location.href = `/order/orderdetail/${id}`
		}
</script>

